---
const { project } = Astro.props;
const data = project.data;
const primaryHref = data.demo || data.github || "#";
---

<article class="content-card group overflow-hidden p-5 transition duration-200 hover:-translate-y-1 hover:border-[var(--color-blue)] sm:p-6">
  <a href={primaryHref} class="link-focus block" target={primaryHref.startsWith("http") ? "_blank" : undefined} rel="noreferrer">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h3 class="text-xl font-semibold text-[var(--color-text)] sm:text-2xl">{data.title}</h3>
        <p class="mt-3 line-clamp-3 text-sm leading-6 text-[var(--color-muted)] sm:text-base">
          {data.description}
        </p>
      </div>
      <span class="grid size-9 shrink-0 place-items-center rounded-full bg-[var(--color-blue-soft)] text-[var(--color-blue-deep)] transition group-hover:rotate-[-8deg]">
        <svg viewBox="0 0 24 24" class="size-4" aria-hidden="true">
          <path d="M7 17 17 7M9 7h8v8" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>
    </div>

    {data.tech?.length > 0 && (
      <div class="mt-5 flex flex-wrap gap-2">
        {data.tech.map((item) => (
          <span class="rounded-full border border-[var(--color-line)] px-3 py-1 text-xs text-[var(--color-blue-deep)]">
            {item}
          </span>
        ))}
      </div>
    )}
  </a>
</article>
