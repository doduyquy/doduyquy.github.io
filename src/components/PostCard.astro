---
const { post } = Astro.props;
const slug = post.id.replace(/\.mdx?$/, "");
const formattedDate = post.data.date.toLocaleDateString("en", {
  month: "short",
  day: "numeric",
  year: "numeric",
});
---

<a href={`/posts/${slug}`} class="content-card link-focus group block p-5 transition duration-200 hover:-translate-y-1 hover:border-[var(--color-blue)] sm:p-6">
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="text-sm text-[var(--color-muted)]">{formattedDate}</p>
      <h2 class="mt-2 text-2xl font-semibold text-[var(--color-text)]">{post.data.title}</h2>
      <p class="mt-3 leading-6 text-[var(--color-muted)]">{post.data.description}</p>
    </div>
    <span class="grid size-9 shrink-0 place-items-center rounded-full bg-[var(--color-blue-soft)] text-[var(--color-blue-deep)]">
      <svg viewBox="0 0 24 24" class="size-4" aria-hidden="true">
        <path d="M7 17 17 7M9 7h8v8" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </span>
  </div>

  {post.data.tags?.length > 0 && (
    <div class="mt-5 flex flex-wrap gap-2">
      {post.data.tags.map((tag) => (
        <span class="rounded-full border border-[var(--color-line)] px-3 py-1 text-xs text-[var(--color-blue-deep)]">
          {tag}
        </span>
      ))}
    </div>
  )}
</a>
