---
const { headings = [] } = Astro.props;
const visibleHeadings = headings.filter((heading) => heading.depth <= 3);
---

<aside class="hidden border-l border-[var(--color-line)] pl-6 lg:block">
  <div class="sticky top-24">
    <button
      class="mb-4 grid size-10 place-items-center rounded-full border border-[var(--color-line)] bg-[var(--color-surface)] text-[var(--color-blue-deep)]"
      type="button"
      aria-label="Table of contents"
      title="Table of contents"
    >
      <svg viewBox="0 0 24 24" class="size-5" aria-hidden="true">
        <path d="M8 6h12M8 12h12M8 18h12M4 6h.01M4 12h.01M4 18h.01" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" />
      </svg>
    </button>

    {visibleHeadings.length > 0 && (
      <nav class="content-card p-4" aria-label="Table of contents">
        <h2 class="mb-3 text-lg font-semibold text-[var(--color-text)]">Table of contents</h2>
        <ol class="space-y-2 text-sm text-[var(--color-muted)]">
          {visibleHeadings.map((heading) => (
            <li style={`padding-left: ${(heading.depth - 2) * 14}px`}>
              <a class="link-focus hover:text-[var(--color-blue-deep)]" href={`#${heading.slug}`}>
                {heading.text}
              </a>
            </li>
          ))}
        </ol>
      </nav>
    )}
  </div>
</aside>
