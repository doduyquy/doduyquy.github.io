---
const { paper } = Astro.props;
const data = paper.data;
---

<article class="content-card group p-5 transition duration-200 hover:-translate-y-1 hover:border-[var(--color-blue)] sm:p-6">
  <a href={data.pdf} class="link-focus block" target={data.pdf?.startsWith("http") ? "_blank" : undefined} rel="noreferrer">
    <div class="flex items-start justify-between gap-4">
      <div>
        <div class="flex flex-wrap items-center gap-2 text-xs text-[var(--color-muted)]">
          {data.venue && <span>{data.venue}</span>}
          {data.year && <span>{data.year}</span>}
          <span class="rounded-full bg-[var(--color-blue-soft)] px-2 py-1 text-[var(--color-blue-deep)]">
            {data.status}
          </span>
        </div>
        <h3 class="mt-3 text-xl font-semibold text-[var(--color-text)] sm:text-2xl">{data.title}</h3>
      </div>
      <span class="grid size-9 shrink-0 place-items-center rounded-full border border-[var(--color-line)] text-[var(--color-blue-deep)] transition group-hover:border-[var(--color-blue)]">
        <svg viewBox="0 0 24 24" class="size-4" aria-hidden="true">
          <path d="M7 3.5h7l4 4V20a.5.5 0 0 1-.5.5h-10A1.5 1.5 0 0 1 6 19V5a1.5 1.5 0 0 1 1-1.5Z" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round" />
          <path d="M14 3.5V8h4M9 13h6M9 16h4" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>
    </div>

    {data.abstract && (
      <p class="mt-4 line-clamp-3 text-sm leading-6 text-[var(--color-muted)] sm:text-base">
        {data.abstract}
      </p>
    )}
  </a>
</article>
