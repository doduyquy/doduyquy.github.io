---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import PaperCard from "../../components/PaperCard.astro";

const papers = await getCollection("papers");
---

<BaseLayout title="Papers | Đỗ Duy Quý">
  <Header />
  <main class="page-shell py-10 sm:py-12">
    <div class="mb-8">
      <p class="mb-3 text-sm uppercase tracking-[0.18em] text-[var(--color-blue-deep)]">Research notes</p>
      <h1 class="text-4xl font-semibold text-[var(--color-text)]">Papers</h1>
    </div>

    <div class="grid gap-5 md:grid-cols-2">
      {papers.map((paper) => <PaperCard paper={paper} />)}
    </div>
  </main>
</BaseLayout>
