---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import ProjectCard from "../../components/ProjectCard.astro";

const projects = await getCollection("projects");
---

<BaseLayout title="Projects | Đỗ Duy Quý">
  <Header />
  <main class="page-shell py-10 sm:py-12">
    <div class="mb-8">
      <p class="mb-3 text-sm uppercase tracking-[0.18em] text-[var(--color-blue-deep)]">Selected work</p>
      <h1 class="text-4xl font-semibold text-[var(--color-text)]">Projects</h1>
    </div>

    <div class="grid gap-5 md:grid-cols-2">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </main>
</BaseLayout>
