---
// Read data from `project` & `papers` -> render to card
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import ProjectCard from "../components/ProjectCard.astro";
import PaperCard from "../components/PaperCard.astro";

const projects = await getCollection("projects", ({ data }) => data.featured);
const papers = await getCollection("papers", ({ data }) => data.featured);
---

<BaseLayout title="Đỗ Duy Quý | Portfolio">

	<Header />

	<main class="page-shell py-7 sm:py-9">
		<section class="intro-panel mb-10 px-6 py-7 sm:px-8 sm:py-8 lg:px-10">
			<svg class="intro-blob" viewBox="0 0 760 420" preserveAspectRatio="none" aria-hidden="true">
				<defs>
					<linearGradient id="introBlobGradient" x1="168" y1="28" x2="586" y2="406" gradientUnits="userSpaceOnUse">
						<stop stop-color="#7BE3CE" />
						<stop offset="1" stop-color="#187DA0" />
					</linearGradient>
				</defs>
				<path
					d="M204 37C287-11 332 54 394 51C487 47 500-9 585 3C674 16 760 88 747 188C734 289 648 377 542 377C433 377 372 414 265 416C156 418 45 386 17 284C-10 185 22 80 112 74C150 72 167 58 204 37Z"
					fill="url(#introBlobGradient)"
					transform="translate(0 35)"
				/>
			</svg>
			<div class="relative z-10 grid gap-6 lg:grid-cols-[1fr_240px_1fr] lg:items-center">
				<div class="order-2 lg:order-1">
					<h2 class="text-2xl font-semibold text-[var(--color-text)] sm:text-3xl">Interests</h2>
					<ul class="mt-4 space-y-3 text-base text-[var(--color-muted)] sm:text-lg">
						<li class="flex gap-3"><span class="mt-2 size-2 rounded-full bg-[var(--color-blue)]"></span>Computer Vision</li>
						<li class="flex gap-3"><span class="mt-2 size-2 rounded-full bg-[var(--color-blue)]"></span>Vision Language Model</li>
						<li class="flex gap-3"><span class="mt-2 size-2 rounded-full bg-[var(--color-blue)]"></span>LLM and Medical AI</li>
					</ul>
				</div>

				<div class="order-1 text-center lg:order-2">
					<img
						src="/avatar_nii.png"
						alt="Portrait of Đỗ Duy Quý"
						class="mx-auto size-24 rounded-full border-4 border-[var(--color-surface)] object-cover shadow-lg shadow-cyan-900/10 sm:size-28"
					/>
					<h1 class="mt-5 text-3xl font-semibold text-[var(--color-text)]">Đỗ Duy Quý</h1>
					<div class="mt-4 flex justify-center gap-3">
						<a href="https://github.com/doduyquy" class="link-focus grid size-10 place-items-center rounded-full border border-[var(--color-line)] text-[var(--color-blue-deep)] transition hover:border-[var(--color-blue)]" aria-label="GitHub">
							<svg viewBox="0 0 24 24" class="size-5" aria-hidden="true">
								<path d="M12 2.8a9.2 9.2 0 0 0-2.9 17.9c.46.08.63-.2.63-.44v-1.58c-2.56.56-3.1-1.1-3.1-1.1-.42-1.08-1.03-1.36-1.03-1.36-.84-.58.06-.57.06-.57.93.07 1.42.96 1.42.96.83 1.42 2.17 1.01 2.7.77.08-.6.32-1.01.58-1.24-2.04-.23-4.18-1.02-4.18-4.54 0-1 .36-1.82.95-2.46-.1-.23-.41-1.17.09-2.43 0 0 .78-.25 2.54.94A8.8 8.8 0 0 1 12 7.33c.78 0 1.56.1 2.29.31 1.76-1.19 2.53-.94 2.53-.94.5 1.26.19 2.2.09 2.43.59.64.95 1.46.95 2.46 0 3.53-2.15 4.3-4.2 4.53.33.29.62.85.62 1.72v2.55c0 .24.17.52.64.43A9.2 9.2 0 0 0 12 2.8Z" fill="currentColor" />
							</svg>
						</a>
						<a href="mailto:doduyquy211@gmail.com" class="link-focus grid size-10 place-items-center rounded-full border border-[var(--color-line)] text-[var(--color-blue-deep)] transition hover:border-[var(--color-blue)]" aria-label="Email">
							<svg viewBox="0 0 24 24" class="size-5" aria-hidden="true">
								<path d="M4.5 6.5h15v11h-15z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
								<path d="m5 7 7 6 7-6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
							</svg>
						</a>
					</div>
				</div>

				<div class="order-3 lg:self-center lg:justify-self-end lg:text-left">
					<h2 class="text-2xl font-semibold text-[var(--color-text)] sm:text-3xl">Education</h2>

					<ul class="mt-4 space-y-3 text-base text-[var(--color-muted)] sm:text-lg">
						<li class="flex gap-3">
							<span class="mt-2 size-2 shrink-0 rounded-full bg-[var(--color-blue)]"></span>
							<span>
								B.E <strong class="text-[var(--color-text)]">Computer Science</strong>
								<br />
								at Sai Gon University.
							</span>
						</li>

						<li class="flex gap-3">
							<span class="mt-2 size-2 shrink-0 rounded-full bg-[var(--color-blue)]"></span>
							<span>
								GPA: <strong class="text-[var(--color-text)]">3.8/4.0</strong>
							</span>
						</li>
					</ul>
				</div>
			</div>
		</section>

		<section class="grid gap-10 lg:grid-cols-2 lg:gap-12">
			<div>
				<div class="mb-5 flex items-end justify-between gap-4">
					<h2 class="text-3xl font-semibold text-[var(--color-text)]">Projects</h2>
					<a href="/projects" class="text-sm text-[var(--color-blue-deep)] hover:underline">View all</a>
				</div>
				<div class="space-y-5">
					{projects.map((project) => <ProjectCard project={project} />)}
				</div>
			</div>

			<div class="lg:border-l lg:border-[var(--color-line)] lg:pl-12">
				<div class="mb-5 flex items-end justify-between gap-4">
					<h2 class="text-3xl font-semibold text-[var(--color-text)]">Papers</h2>
					<a href="/papers" class="text-sm text-[var(--color-blue-deep)] hover:underline">View all</a>
				</div>
				<div class="space-y-5">
					{papers.map((paper) => <PaperCard paper={paper} />)}
				</div>
			</div>
		</section>

	</main>
</BaseLayout>
